COMPOSE_PROJECT_NAME=codex-feishu-bridge
NODE_IMAGE=node:20-bookworm
DEV_IMAGE_NAME=codex-feishu-bridge-dev:local
WORKSPACE_PATH=/workspace/codex-feishu-bridge
BRIDGE_PORT=8787
BRIDGE_WS_PATH=/ws
BRIDGE_STATE_DIR=.tmp
BRIDGE_CODEX_HOME=/workspace/codex-feishu-bridge/.tmp/codex-home
BRIDGE_UPLOADS_DIR=/workspace/codex-feishu-bridge/.tmp/uploads
CODEX_RUNTIME_BACKEND=mock
CODEX_APP_SERVER_BIN=codex
CODEX_APP_SERVER_ARGS=app-server
HOST_CODEX_HOME=../.tmp/codex-home
HOST_CODEX_BIN_DIR=/tmp
PUBLIC_BASE_URL=
MOCK_AUTO_COMPLETE_LOGIN=true
FEISHU_BASE_URL=https://open.feishu.cn
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_DEFAULT_CHAT_ID=
FEISHU_DEFAULT_CHAT_NAME=
